# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (per-user rate limiting; flashcard generation degrades gracefully if unset)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Anthropic (flashcard generation — required)
ANTHROPIC_API_KEY=sk-ant-...

# Analytics
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Teachable SSO (for dual-mode auth)
TEACHABLE_CLIENT_ID=
TEACHABLE_CLIENT_SECRET=
TEACHABLE_SITE_URL=https://medcognito.teachable.com
