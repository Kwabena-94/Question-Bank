# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (per-user rate limiting; flashcard generation degrades gracefully if unset)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Anthropic (flashcard generation — required)
# CAUTION: do NOT `source .env.local` or otherwise export ANTHROPIC_API_KEY in
# your shell. dotenv (and @next/env) will not override an existing process.env
# value, so an empty/stale shell var silently masks the value in .env.local
# and the route returns 503 "Flashcard generation is not configured."
# If generation is failing locally, run: `unset ANTHROPIC_API_KEY` then restart
# the dev server. (Vercel is unaffected — it injects only what you configure.)
ANTHROPIC_API_KEY=sk-ant-...

# Cron
CRON_SECRET=replace-with-a-random-secret

# Analytics
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Teachable SSO (for dual-mode auth)
TEACHABLE_CLIENT_ID=
TEACHABLE_CLIENT_SECRET=
TEACHABLE_SITE_URL=https://medcognito.teachable.com
